  fhir:differential [
     fhir:element ( [
       fhir:id [ fhir:v "Identifier" ] ;
       fhir:path [ fhir:v "Identifier" ] ;
       fhir:short [ fhir:v "Tipo de dato para identificar un paciente en Chile" ] ;
       fhir:comment [ fhir:v "Variable de identificación" ]
     ] [
       fhir:id [ fhir:v "Identifier.extension" ] ;
       fhir:path [ fhir:v "Identifier.extension" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "Identifier.extension:digitoVerificador" ] ;
       fhir:path [ fhir:v "Identifier.extension" ] ;
       fhir:sliceName [ fhir:v "digitoVerificador" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "Extension"^^xsd:anyURI ;
           fhir:l fhir:Extension
         ] ;
         fhir:profile ( [
           fhir:v "http://hl7.org/fhir/StructureDefinition/identifier-checkDigit"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/StructureDefinition/identifier-checkDigit>
         ] )
       ] ) ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Identifier.use" ] ;
       fhir:path [ fhir:v "Identifier.use" ] ;
       fhir:definition [ fhir:v "De contar el Paciente con una Cédula de Identidad Nacional, se sugiere el uso de esta como identificador" ] ;
       fhir:comment [ fhir:v "Se definirá como official pues en una primera etapa solo se considerarán los identidicadores en esa categoría. Para una segunda etapa se abrirá este elemento para cualquier clase de identificador" ] ;
       fhir:binding [
         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "http://hl7.org/fhir/ValueSet/identifier-use"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/ValueSet/identifier-use>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Identifier.type" ] ;
       fhir:path [ fhir:v "Identifier.type" ] ;
       fhir:short [ fhir:v "Tipo de documento RUN" ] ;
       fhir:definition [ fhir:v "Tipo de documento definido para RUN" ] ;
       fhir:binding [
         fhir:strength [ fhir:v "extensible" ] ;
         fhir:description [ fhir:v "Value Set de Tipos de Documentos y CI Nacionales" ] ;
         fhir:valueSet [
           fhir:v "https://interoperabilidad.minsal.cl/fhir/ig/eis/ValueSet/eis-TipodeIdentificador-VS"^^xsd:anyURI ;
           fhir:l <https://interoperabilidad.minsal.cl/fhir/ig/eis/ValueSet/eis-TipodeIdentificador-VS>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Identifier.type.coding" ] ;
       fhir:path [ fhir:v "Identifier.type.coding" ] ;
       fhir:pattern [
         a fhir:Coding ;
         fhir:system [
           fhir:v "https://interoperabilidad.minsal.cl/fhir/ig/eis/CodeSystem/eis-TipodeIdentificador-CS"^^xsd:anyURI ;
           fhir:l <https://interoperabilidad.minsal.cl/fhir/ig/eis/CodeSystem/eis-TipodeIdentificador-CS>
         ] ;
         fhir:code [ fhir:v "1" ]
       ]
     ] [
       fhir:id [ fhir:v "Identifier.type.coding.system" ] ;
       fhir:path [ fhir:v "Identifier.type.coding.system" ] ;
       fhir:short [ fhir:v "Sistema de identificación de tipos de documentos" ] ;
       fhir:definition [ fhir:v "Sistema mediante el cual se obtienen los códigos para un determinado tipo de documento" ] ;
       fhir:comment [ fhir:v "En la URL del sistema se describe el set de códigos. Por ejemplo si se desea usar Cédula de identidad el código es NNxxx en donde xxx corresponde al identificador del país según la norma iso3166-1-N. Dado lo anterior si fuera Chile, el tipo de documento sería NNCL. En el Caso de Usar un Pasaporte este no requiere identificar país de origen dado que este es un elemento adicional, por lo que independiente del país el código será PPT según el VS indicado" ]
     ] [
       fhir:id [ fhir:v "Identifier.type.coding.code" ] ;
       fhir:path [ fhir:v "Identifier.type.coding.code" ] ;
       fhir:short [ fhir:v "Código para RUN" ] ;
       fhir:definition [ fhir:v "Código para RUN" ]
     ] [
       fhir:id [ fhir:v "Identifier.type.coding.display" ] ;
       fhir:path [ fhir:v "Identifier.type.coding.display" ] ;
       fhir:short [ fhir:v "Cédula de Identidad Chilena" ] ;
       fhir:definition [ fhir:v "Glosa del Código Documento" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Identifier.value" ] ;
       fhir:path [ fhir:v "Identifier.value" ] ;
       fhir:short [ fhir:v "Número RUN" ] ;
